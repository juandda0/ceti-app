# Ceti — plantilla (sin secretos). Copia a `.env` y rellena con tus valores reales.

EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=
EXPO_PUBLIC_FIREBASE_MEASUREMENT_ID=

# Google Sign-In: Web client ID (Firebase → Auth → Google)
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
# iOS (opcional): solo si compilas para iOS
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_IOS_URL_SCHEME=

EXPO_PUBLIC_FEATURE_APPLE_SIGNIN=0

# EXPO_PUBLIC_USE_FUNCTIONS_EMULATOR=1

EXPO_PUBLIC_APP_ENV=development

# Descarga `google-services.json` (app Android en Firebase) y colócalo en la raíz del repo
# para builds nativos Android. Ver: https://firebase.google.com/docs/android/setup

# Opcional: EAS / iOS
# EAS_PROJECT_ID=
# IOS_BUNDLE_ID=com.juanndda.ceti
